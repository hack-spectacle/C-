#!/bin/bash

APP_NAME="C[] Launcher"
BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
NEEDED_DIR="$BASE_DIR/Needed"
WORKSPACE_DIR="$BASE_DIR/WorkSpace"

mkdir -p "$NEEDED_DIR"
mkdir -p "$WORKSPACE_DIR"

alert() {
osascript <<EOF
display dialog "$1" with title "$APP_NAME" buttons {"OK"} default button "OK"
EOF
}

menu() {
osascript <<EOF
choose from list {"Start Launcher", "Create Project Folders", "Open Workspace", "Show Info", "Exit"} with title "$APP_NAME" with prompt "C[] Launcher\n\nSelect an option:"
EOF
}

show_info() {
alert "C[] Launcher\n\nVersion: 1.0\nMade by Hack-Spectacle\n\nSafe shell GUI launcher for Mac."
}

create_folders() {
mkdir -p "$NEEDED_DIR/Modules"
mkdir -p "$WORKSPACE_DIR/Scripts"
mkdir -p "$WORKSPACE_DIR/Logs"
alert "Folders created successfully."
}

open_workspace() {
open "$WORKSPACE_DIR"
}

start_launcher() {
alert "C[] Launcher started."
}

while true; do
    choice=$(menu)

    if [ "$choice" = "false" ] || [ "$choice" = "Exit" ]; then
        alert "Goodbye."
        exit 0
    fi

    case "$choice" in
        "Start Launcher")
            start_launcher
            ;;
        "Create Project Folders")
            create_folders
            ;;
        "Open Workspace")
            open_workspace
            ;;
        "Show Info")
            show_info
            ;;
    esac
done
