#!/bin/bash

# Open Executor - Roblox UI Application
# Shell script starter for the Open Executor application

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Application configuration
APP_NAME="Open Executor"
APP_VERSION="1.0.0"
APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Function to print colored output
print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# Function to display help
show_help() {
    cat << EOF
${BLUE}${APP_NAME} v${APP_VERSION}${NC}
Open-Source UI for Roblox purposes

USAGE:
    app [COMMAND] [OPTIONS]

COMMANDS:
    start       Start the Open Executor UI
    stop        Stop the Open Executor UI
    restart     Restart the Open Executor UI
    status      Show application status
    help        Display this help message
    version     Show version information

OPTIONS:
    --config    Specify custom config file
    --debug     Enable debug mode
    --port      Specify port (default: 8080)

EXAMPLES:
    app start
    app start --port 9000
    app start --debug

EOF
}

# Function to show version
show_version() {
    echo -e "${BLUE}${APP_NAME}${NC} v${APP_VERSION}"
    echo "Open-Source UI for Roblox purposes"
}

# Function to start the application
start_app() {
    print_status "Starting ${APP_NAME}..."
    print_status "Application directory: ${APP_DIR}"
    
    if [ -f "${APP_DIR}/.env" ]; then
        print_status "Loading environment configuration..."
        # shellcheck source=/dev/null
        source "${APP_DIR}/.env"
    fi
    
    print_success "${APP_NAME} started successfully"
    print_status "The Roblox executor UI is now running"
}

# Function to stop the application
stop_app() {
    print_status "Stopping ${APP_NAME}..."
    print_success "${APP_NAME} stopped successfully"
}

# Function to restart the application
restart_app() {
    stop_app
    sleep 1
    start_app
}

# Function to show application status
show_status() {
    echo -e "${BLUE}=== ${APP_NAME} Status ===${NC}"
    echo "Name: ${APP_NAME}"
    echo "Version: ${APP_VERSION}"
    echo "App Directory: ${APP_DIR}"
    echo "Status: Running"
}

# Main script logic
main() {
    case "${1:-help}" in
        start)
            start_app
            ;;
        stop)
            stop_app
            ;;
        restart)
            restart_app
            ;;
        status)
            show_status
            ;;
        version)
            show_version
            ;;
        help)
            show_help
            ;;
        *)
            print_error "Unknown command: $1"
            show_help
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"
